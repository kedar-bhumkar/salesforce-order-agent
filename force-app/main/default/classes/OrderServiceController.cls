/**
 * @description Controller class for Order Service operations
 * @author Generated by OrderServiceAgent
 * @date 2026-02-27
 */
public with sharing class OrderServiceController {

    /**
     * @description Search for an order by Order ID or Email
     * @param orderId The order number to search for
     * @param customerEmail The customer email to search for
     * @return OrderSearchResult containing order details
     */
    @AuraEnabled
    public static OrderSearchResult searchOrder(String orderId, String customerEmail) {
        try {
            List<Order> orders = new List<Order>();

            if (String.isNotBlank(orderId)) {
                orders = [
                    SELECT Id, OrderNumber, Status, TotalAmount,
                           AccountId, Account.Name, CreatedDate
                    FROM Order
                    WHERE OrderNumber = :orderId
                    LIMIT 1
                ];
            } else if (String.isNotBlank(customerEmail)) {
                orders = [
                    SELECT Id, OrderNumber, Status, TotalAmount,
                           AccountId, Account.Name, CreatedDate
                    FROM Order
                    WHERE CustomerAuthorizedBy.Email = :customerEmail
                    ORDER BY CreatedDate DESC
                    LIMIT 1
                ];
            }

            if (orders.isEmpty()) {
                return new OrderSearchResult(false, 'No order found', null);
            }

            return new OrderSearchResult(true, 'Order found', orders[0]);

        } catch (Exception e) {
            System.debug('Error searching order: ' + e.getMessage());
            return new OrderSearchResult(false, 'Error: ' + e.getMessage(), null);
        }
    }

    /**
     * @description Submit a refund request for an order
     * @param orderId The order number for refund
     * @param refundReason The reason for requesting refund
     * @param customerEmail Customer email for confirmation
     * @return RefundRequestResult containing request details
     */
    @AuraEnabled
    public static RefundRequestResult submitRefundRequest(
        String orderId,
        String refundReason,
        String customerEmail
    ) {
        try {
            // Validate inputs
            if (String.isBlank(orderId) || String.isBlank(refundReason)) {
                return new RefundRequestResult(
                    false,
                    'Order ID and refund reason are required',
                    null,
                    null
                );
            }

            // Get the order
            List<Order> orders = [
                SELECT Id, OrderNumber, AccountId, Status, TotalAmount
                FROM Order
                WHERE OrderNumber = :orderId
                LIMIT 1
            ];

            if (orders.isEmpty()) {
                return new RefundRequestResult(
                    false,
                    'Order not found',
                    null,
                    null
                );
            }

            Order order = orders[0];

            // Create a Case for the refund request
            Case refundCase = new Case(
                Subject = 'Refund Request - Order ' + orderId,
                Description = String.format(
                    'Customer has requested a refund for Order {0}.\n\n' +
                    'Reason: {1}\n' +
                    'Customer Email: {2}\n\n' +
                    'This case has been automatically created by the Order Service Agent.',
                    new List<String>{orderId, refundReason, customerEmail}
                ),
                Status = 'New',
                Origin = 'Agent',
                Type = 'Refund Request',
                Priority = 'Medium',
                AccountId = order.AccountId
            );

            insert refundCase;

            // Reload to get the Case Number
            refundCase = [
                SELECT Id, CaseNumber, Status
                FROM Case
                WHERE Id = :refundCase.Id
                LIMIT 1
            ];

            // Send confirmation email (simplified - in production use Email Template)
            sendRefundConfirmationEmail(refundCase, order, customerEmail, refundReason);

            return new RefundRequestResult(
                true,
                'Refund request submitted successfully',
                refundCase.CaseNumber,
                'Submitted - Pending Review'
            );

        } catch (Exception e) {
            System.debug('Error submitting refund: ' + e.getMessage());
            return new RefundRequestResult(
                false,
                'Error: ' + e.getMessage(),
                null,
                null
            );
        }
    }

    /**
     * @description Send refund confirmation email
     * @param refundCase The created case
     * @param order The order being refunded
     * @param customerEmail Customer email address
     * @param refundReason Reason for refund
     */
    private static void sendRefundConfirmationEmail(
        Case refundCase,
        Order order,
        String customerEmail,
        String refundReason
    ) {
        try {
            Messaging.SingleEmailMessage email = new Messaging.SingleEmailMessage();
            email.setToAddresses(new List<String>{customerEmail});
            email.setSubject('Refund Request Confirmation - Case ' + refundCase.CaseNumber);

            String emailBody = String.format(
                'Dear Customer,\n\n' +
                'Your refund request has been received and is being processed.\n\n' +
                'Refund Request Details:\n' +
                '- Case Number: {0}\n' +
                '- Order ID: {1}\n' +
                '- Status: {2}\n' +
                '- Reason: {3}\n\n' +
                'Our team will review your request and process the refund within 5-7 business days.\n' +
                'You will receive another email once the refund has been processed.\n\n' +
                'If you have any questions, please contact our customer service team with your case number.\n\n' +
                'Thank you,\n' +
                'Customer Service Team',
                new List<String>{
                    refundCase.CaseNumber,
                    order.OrderNumber,
                    refundCase.Status,
                    refundReason
                }
            );

            email.setPlainTextBody(emailBody);

            Messaging.sendEmail(new List<Messaging.SingleEmailMessage>{email});

        } catch (Exception e) {
            System.debug('Error sending email: ' + e.getMessage());
            // Don't throw - email failure shouldn't fail the refund request
        }
    }

    /**
     * @description Wrapper class for order search results
     */
    public class OrderSearchResult {
        @AuraEnabled public Boolean success;
        @AuraEnabled public String message;
        @AuraEnabled public Order orderRecord;

        public OrderSearchResult(Boolean success, String message, Order orderRecord) {
            this.success = success;
            this.message = message;
            this.orderRecord = orderRecord;
        }
    }

    /**
     * @description Wrapper class for refund request results
     */
    public class RefundRequestResult {
        @AuraEnabled public Boolean success;
        @AuraEnabled public String message;
        @AuraEnabled public String refundRequestId;
        @AuraEnabled public String status;

        public RefundRequestResult(
            Boolean success,
            String message,
            String refundRequestId,
            String status
        ) {
            this.success = success;
            this.message = message;
            this.refundRequestId = refundRequestId;
            this.status = status;
        }
    }
}
