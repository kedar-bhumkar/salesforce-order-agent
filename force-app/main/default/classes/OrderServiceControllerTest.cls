    @TestSetup
    static void setupTestData() {
        // Create test Account
        Account testAccount = new Account(
            Name = 'Test Customer Account'
        );
        insert testAccount;

        // Create test Contact
        Contact testContact = new Contact(
            FirstName = 'Test',
            LastName = 'Customer',
            Email = 'testcustomer@example.com',
            AccountId = testAccount.Id
        );
        insert testContact;

        // Create test Order
        Order testOrder = new Order(
            AccountId = testAccount.Id,
            EffectiveDate = Date.today(),
            Status = 'Draft',
            OrderNumber = 'ORD-12345',
            CustomerAuthorizedById = testContact.Id
        );
        insert testOrder;

        testOrder.Status = 'Activated';
        update testOrder;
    }

    @isTest
    static void testSearchOrderById_Success() {
        // Given
        String orderId = 'ORD-12345';

        // When
        Test.startTest();
        OrderServiceController.OrderSearchResult result =
            OrderServiceController.searchOrder(orderId, null);
        Test.stopTest();

        // Then
        System.assertEquals(true, result.success, 'Search should be successful');
        System.assertEquals('Order found', result.message, 'Should return success message');
        System.assertNotEquals(null, result.orderRecord, 'Should return order record');
        System.assertEquals('ORD-12345', result.orderRecord.OrderNumber, 'Should return correct order');
    }

