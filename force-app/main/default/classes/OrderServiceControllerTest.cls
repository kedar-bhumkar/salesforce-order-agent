    @isTest
    static void testSubmitRefundRequest_BulkProcessing() {
        // Given
        List<String> orderIds = new List<String>{'ORD-12345'};
        String refundReason = 'Bulk test';
        String customerEmail = 'testcustomer@example.com';

        // When
        Test.startTest();
        List<OrderServiceController.RefundRequestResult> results =
            new List<OrderServiceController.RefundRequestResult>();

        for (String orderId : orderIds) {
            results.add(
                OrderServiceController.submitRefundRequest(orderId, refundReason, customerEmail)
            );
        }
        Test.stopTest();

        // Then
        for (OrderServiceController.RefundRequestResult result : results) {
            System.assertEquals(true, result.success, 'All bulk requests should succeed');
        }

        // Verify governor limits
        System.assert(Limits.getQueries() < Limits.getLimitQueries(), 'Should not exceed SOQL limits');
        System.assert(Limits.getDmlStatements() < Limits.getLimitDmlStatements(), 'Should not exceed DML limits');
    }
