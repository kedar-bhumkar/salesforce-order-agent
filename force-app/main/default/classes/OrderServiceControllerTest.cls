    @isTest
    static void testSubmitRefundRequest_Success() {
        // Given
        String orderId = 'ORD-12345';
        String refundReason = 'Product defect';
        String customerEmail = 'testcustomer@example.com';

        // When
        Test.startTest();
        OrderServiceController.RefundRequestResult result =
            OrderServiceController.submitRefundRequest(orderId, refundReason, customerEmail);
        Test.stopTest();

        // Then
        System.assertEquals(true, result.success, 'Refund request should be successful');
        System.assertEquals(
            'Refund request submitted successfully',
            result.message,
            'Should return success message'
        );
        System.assertNotEquals(null, result.refundRequestId, 'Should return case number');
        System.assertEquals(
            'Submitted - Pending Review',
            result.status,
            'Should return correct status'
        );

        // Verify Case was created
        List<Case> cases = [
            SELECT Id, Subject, Type, Status
            FROM Case
            WHERE Type = 'Refund Request'
        ];
        System.assertEquals(1, cases.size(), 'Should create one case');
        System.assert(
            cases[0].Subject.contains('ORD-12345'),
            'Case subject should contain order ID'
        );
    }

