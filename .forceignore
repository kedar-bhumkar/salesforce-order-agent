# List files or directories below to ignore them when running force:source:push, force:source:pull, and force:source:status
# More information: https://developer.salesforce.com/docs/atlas.en-us.sfdx_dev.meta/sfdx_dev/sfdx_dev_exclude_source.htm

package.xml

# LWC configuration files
**/jsconfig.json
**/.eslintrc.json

# LWC Jest
**/__tests__/**

# Profiles & Permission Sets - Exclude irrelevant
**profiles/**
!**profiles/Admin.profile*

# Standard Object Definitions
**/standardValueSets/*
**/standardValueSetTranslations/*

# Translations
**/objectTranslations/**

# Experience Cloud sites
**/siteDotComSites/**

# Standard Reports
**/reports/unfiled$public/**

# Exclude everything from the standard dashboards
**/dashboards/unfiled$public/**

# Static resources
**/staticresources/**

# Document
**/documents/**
